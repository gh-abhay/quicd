# Superd Configuration File
# 
# This file demonstrates all available configuration options for Superd.
# Copy this file to /etc/superd/config.toml or specify with --config flag.

# =============================================================================
# Network I/O Layer Configuration
# =============================================================================
[network_io]

# Number of dedicated I/O threads for UDP operations
# Default: Auto-detected (25% of CPUs, min=1, max=8)
# Range: 1-16
threads = 4

# Enable CPU pinning for I/O threads
# Pins each thread to a specific CPU core for cache locality
# Default: true (disable in containers with --no-pin-io)
enable_cpu_pinning = true

# Enable NUMA-aware thread placement
# Automatically detects and uses NUMA topology for optimal performance
# Default: false (enable on multi-socket servers)
enable_numa_awareness = false

# Thread priority for I/O threads
# Options: "low", "normal", "high", "max"
# Default: "high" (requires CAP_SYS_NICE on Linux)
thread_priority = "high"

# CPU affinity strategy for thread placement
# Options:
#   - "auto": Let OS scheduler decide (no pinning)
#   - "interleaved": Alternate between cores (I/O on even, QUIC on odd)
#   - "sequential": Consecutive cores (I/O: 0-3, QUIC: 4-7)
# Default: "interleaved"
cpu_affinity_strategy = "interleaved"

# =============================================================================
# QUIC Protocol Layer Configuration
# =============================================================================
[quic_protocol]

# Number of QUIC protocol handler threads
# Should match network_io.threads for 1:1 mapping
# Default: Auto-detected (equals I/O threads)
# Range: 1-16
threads = 4

# Enable CPU pinning for QUIC handlers
# Default: true
enable_cpu_pinning = true

# Thread priority for QUIC handlers
# Options: "low", "normal", "high", "max"
# Default: "normal"
thread_priority = "normal"

# Channel buffer size between I/O threads and QUIC handlers
# Larger buffers prevent backpressure under traffic spikes
# Default: 8192 packets
# Range: 1024-65536
channel_buffer_size = 8192

# =============================================================================
# Server Configuration
# =============================================================================
[server]

# Address and port to listen on
# IPv4: "0.0.0.0:4433"
# IPv6: "[::]:4433"
# Specific IP: "192.168.1.100:4433"
# Default: "0.0.0.0:4433"
listen_addr = "0.0.0.0:4433"

# Maximum concurrent connections
# Discord-inspired high concurrency limit
# Default: 100000
# Range: 100-1000000
max_connections = 100000

# UDP socket receive buffer size (bytes)
# Cloudflare-proven large buffer for traffic spikes
# Default: 8388608 (8 MB)
# Range: 262144-16777216 (256 KB - 16 MB)
socket_recv_buffer_size = 8388608

# UDP socket send buffer size (bytes)
# Default: 8388608 (8 MB)
# Range: 262144-16777216 (256 KB - 16 MB)
socket_send_buffer_size = 8388608

# Enable SO_REUSEPORT for kernel-level load balancing
# Allows multiple I/O threads to bind to the same port
# Default: true (disable on older kernels)
enable_reuseport = true

# =============================================================================
# Tokio Runtime Configuration
# =============================================================================
[tokio_runtime]

# Number of Tokio worker threads
# Default: Auto-detected (remaining CPUs after I/O and QUIC)
# Range: 1-64
worker_threads = 4

# CPU allocation mode for Tokio runtime
# Options:
#   - "dedicated": Tokio uses CPUs not allocated to I/O/QUIC
#   - "shared": Tokio shares CPUs with I/O/QUIC threads
# Default: "dedicated"
# Note: Use "shared" only after profiling shows I/O threads are idle
cpu_mode = "dedicated"

# =============================================================================
# Monitoring Configuration
# =============================================================================
[monitoring]

# Enable performance metrics collection
# Default: true
enable_metrics = true

# Metrics logging interval (seconds)
# Default: 10
# Range: 1-300
metrics_interval = 10

# Enable debug-level logging
# Warning: Significant performance impact
# Default: false
debug_mode = false

# =============================================================================
# Example Configurations for Different Scenarios
# =============================================================================

# -----------------------------------------------------------------------------
# High-Performance Server (16+ cores, production)
# -----------------------------------------------------------------------------
# [network_io]
# threads = 8
# enable_cpu_pinning = true
# enable_numa_awareness = true
# thread_priority = "high"
# cpu_affinity_strategy = "interleaved"
#
# [quic_protocol]
# threads = 8
# enable_cpu_pinning = true
# thread_priority = "normal"
# channel_buffer_size = 16384
#
# [server]
# listen_addr = "0.0.0.0:4433"
# max_connections = 500000
# socket_recv_buffer_size = 16777216  # 16 MB
# socket_send_buffer_size = 16777216  # 16 MB
# enable_reuseport = true
#
# [tokio_runtime]
# worker_threads = 8
# cpu_mode = "dedicated"
#
# [monitoring]
# enable_metrics = true
# metrics_interval = 10
# debug_mode = false

# -----------------------------------------------------------------------------
# Low-Latency Server (8 cores, real-time applications)
# -----------------------------------------------------------------------------
# [network_io]
# threads = 2
# enable_cpu_pinning = true
# thread_priority = "max"  # Requires root/CAP_SYS_NICE
# cpu_affinity_strategy = "interleaved"
#
# [quic_protocol]
# threads = 2
# enable_cpu_pinning = true
# thread_priority = "high"
# channel_buffer_size = 4096  # Smaller buffer for lower latency
#
# [server]
# listen_addr = "0.0.0.0:4433"
# max_connections = 50000
# socket_recv_buffer_size = 4194304  # 4 MB
# socket_send_buffer_size = 4194304  # 4 MB
# enable_reuseport = true
#
# [tokio_runtime]
# worker_threads = 4
# cpu_mode = "dedicated"
#
# [monitoring]
# enable_metrics = true
# metrics_interval = 5
# debug_mode = false

# -----------------------------------------------------------------------------
# Development Laptop (4 cores, local testing)
# -----------------------------------------------------------------------------
# [network_io]
# threads = 1
# enable_cpu_pinning = false
# thread_priority = "normal"
# cpu_affinity_strategy = "auto"
#
# [quic_protocol]
# threads = 1
# enable_cpu_pinning = false
# thread_priority = "normal"
# channel_buffer_size = 1024
#
# [server]
# listen_addr = "127.0.0.1:4433"
# max_connections = 1000
# socket_recv_buffer_size = 262144  # 256 KB
# socket_send_buffer_size = 262144  # 256 KB
# enable_reuseport = false
#
# [tokio_runtime]
# worker_threads = 2
# cpu_mode = "shared"
#
# [monitoring]
# enable_metrics = true
# metrics_interval = 10
# debug_mode = true

# -----------------------------------------------------------------------------
# Container/Kubernetes (no CPU affinity)
# -----------------------------------------------------------------------------
# [network_io]
# threads = 2
# enable_cpu_pinning = false
# enable_numa_awareness = false
# thread_priority = "normal"
# cpu_affinity_strategy = "auto"
#
# [quic_protocol]
# threads = 2
# enable_cpu_pinning = false
# thread_priority = "normal"
# channel_buffer_size = 8192
#
# [server]
# listen_addr = "0.0.0.0:4433"
# max_connections = 10000
# socket_recv_buffer_size = 8388608  # 8 MB
# socket_send_buffer_size = 8388608  # 8 MB
# enable_reuseport = true
#
# [tokio_runtime]
# worker_threads = 2
# cpu_mode = "shared"
#
# [monitoring]
# enable_metrics = true
# metrics_interval = 10
# debug_mode = false

# =============================================================================
# Performance Tuning Notes
# =============================================================================
#
# 1. Thread Count Guidelines:
#    - I/O threads: 25% of total CPUs (min=1, max=8)
#    - QUIC handlers: Should equal I/O threads (1:1 mapping)
#    - Tokio workers: Remaining CPUs (or shared in cpu_mode="shared")
#
# 2. CPU Pinning:
#    - Enable for production servers (bare metal)
#    - Disable for containers/VMs with dynamic CPU allocation
#    - Interleaved strategy best for most cases
#
# 3. Buffer Sizes:
#    - Larger socket buffers handle traffic spikes better
#    - Larger channel buffers prevent backpressure
#    - Smaller buffers reduce latency (but increase packet loss risk)
#
# 4. Thread Priorities:
#    - High/max for I/O threads (minimize packet loss)
#    - Normal for QUIC handlers (balanced performance)
#    - Requires CAP_SYS_NICE on Linux for high/max
#
# 5. Connection Limits:
#    - Set based on available memory (each connection ~1-10 KB)
#    - Higher limits require more CPU for connection management
#    - Discord: 5M users = ~100K connections per server
#
# 6. Monitoring:
#    - Always enable metrics in production
#    - Longer intervals (10s+) reduce overhead
#    - Debug mode only for troubleshooting
#
# =============================================================================
# System Configuration Recommendations
# =============================================================================
#
# Linux sysctl settings for optimal performance:
#
#   # Increase UDP buffer sizes
#   net.core.rmem_max = 16777216
#   net.core.wmem_max = 16777216
#   net.core.rmem_default = 8388608
#   net.core.wmem_default = 8388608
#
#   # Increase socket buffer limits
#   net.ipv4.udp_mem = 8388608 12582912 16777216
#   net.ipv4.udp_rmem_min = 16384
#   net.ipv4.udp_wmem_min = 16384
#
#   # Enable SO_REUSEPORT
#   net.core.somaxconn = 65535
#
#   # Disable reverse path filtering (if using multiple NICs)
#   net.ipv4.conf.all.rp_filter = 0
#
# Apply with: sudo sysctl -p
#
# =============================================================================
