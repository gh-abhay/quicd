# superd Configuration File
#
# This is a TOML configuration file for superd daemon.
# All settings have production-ready defaults optimized for maximum performance.
#
# CLI arguments override these settings.

# ==============================================================================
# Network I/O Layer Configuration
# ==============================================================================
[network_io]
# Number of dedicated network I/O threads
# Default: auto-detected (25% of CPUs, min=1, max=8)
#
# Examples:
#   1-4 cores: 1 thread
#   5-8 cores: 2 threads
#   9-16 cores: 4 threads
#   17+ cores: 8 threads (cap)
#
# Each thread can handle ~500K pps (Cloudflare proven).
threads = "auto"  # Or specific number: threads = 4

# Enable CPU pinning for network I/O threads
# Default: true
#
# When enabled:
# - Each thread is pinned to a specific CPU core
# - Hot L1/L2 cache for socket operations
# - Zero context switches during packet RX/TX
# - Predictable performance
#
# Disable only for:
# - Containerized environments without CPU affinity support
# - Testing/debugging
enable_cpu_pinning = true

# Enable NUMA-aware thread placement
# Default: true (on NUMA systems)
#
# When enabled:
# - Threads placed on same NUMA node as NIC
# - Avoids 4x cross-NUMA memory access penalty
# - Critical for >1M pps throughput
enable_numa_awareness = true

# Thread priority: "low", "normal", "high", "max"
# Default: "high"
#
# Network I/O threads get high priority to minimize packet loss.
thread_priority = "high"

# CPU affinity strategy: "auto", "interleaved", "sequential"
# Default: "interleaved"
#
# - auto: No pinning (let OS decide)
# - interleaved: I/O on even cores (0,2,4...), QUIC on odd cores (1,3,5...)
# - sequential: I/O on first N cores, QUIC on next N cores
cpu_affinity_strategy = "interleaved"

# ==============================================================================
# QUIC Protocol Handler Configuration
# ==============================================================================
[quic_protocol]
# Number of QUIC protocol handler threads
# Default: auto-detected (equals network_io.threads)
#
# MUST equal network_io.threads for 1:1 channel mapping.
# Each handler processes packets from one I/O thread.
threads = "auto"  # Or match network_io: threads = 4

# Enable CPU pinning for QUIC handlers
# Default: true
#
# When enabled:
# - Each handler pinned to CPU adjacent to its I/O thread
# - Cache locality (L3 cache sharing)
# - Zero context switches during processing
enable_cpu_pinning = true

# Thread priority: "low", "normal", "high", "max"
# Default: "normal"
#
# QUIC handlers run at normal priority by default.
# For ultra-low latency (<100µs), use "high".
thread_priority = "normal"

# Channel buffer size (packets per handler)
# Default: 8192
#
# Each I/O thread → QUIC handler pair has a dedicated channel.
# Larger buffers prevent backpressure during traffic bursts.
#
# Memory: 8192 packets × 1500 bytes ≈ 12 MB per channel
channel_buffer_size = 8192

# ==============================================================================
# Tokio Runtime Configuration
# ==============================================================================
[tokio_runtime]
# Number of Tokio worker threads
# Default: auto-detected based on cpu_mode
#
# - dedicated mode: num_cpus - (io_threads + quic_threads)
# - shared mode: num_cpus
#
# Set to specific number to override auto-detection.
# worker_threads = 8

# CPU allocation mode: "dedicated" or "shared"
# Default: "dedicated" (safe, predictable)
#
# dedicated: Tokio workers use only CPUs not used by I/O/QUIC
#   - Safe: Zero cache pollution
#   - Predictable: No context switch interference
#   - Proven: Matches production systems
#
# shared: Tokio workers can use all CPUs (work-stealing)
#   - Efficient: Uses idle CPU cycles from I/O/QUIC
#   - Requires: I/O+QUIC < 50% CPU usage (verify with profiling)
#   - Risky: Can cause cache pollution if I/O/QUIC > 75% CPU
#
# Recommendation: Start with "dedicated", switch to "shared" after profiling.
cpu_mode = "dedicated"

# Enable CPU pinning for Tokio workers
# Default: false (let work-stealing scheduler decide)
#
# When enabled:
# - Each Tokio worker is pinned to a specific CPU
# - Reduces cache misses but prevents work-stealing benefits
# - Only useful for specialized workloads
enable_cpu_pinning = false

# Thread stack size for Tokio workers (bytes)
# Default: none (uses Tokio default: 2MB)
#
# Increase only if you see stack overflow errors.
# thread_stack_size = 2097152  # 2 MB

# ==============================================================================
# Server Configuration
# ==============================================================================
[server]
# UDP socket address to bind to
listen_addr = "0.0.0.0:4433"

# Maximum concurrent QUIC connections
# Default: 100,000
#
# Memory estimation:
# - Per connection: ~8.5 KB (8KB QUIC + 500B Tokio task)
# - 100K connections: ~850 MB
# - 1M connections: ~8.5 GB
max_connections = 100000

# Socket receive buffer size (SO_RCVBUF) in bytes
# Default: 8 MB
#
# Cloudflare-proven large buffers prevent packet loss.
# Kernel allocates this much memory per socket.
socket_recv_buffer_size = 8388608  # 8 MB

# Socket send buffer size (SO_SNDBUF) in bytes
# Default: 8 MB
socket_send_buffer_size = 8388608  # 8 MB

# Enable SO_REUSEPORT
# Default: true
#
# Required for multi-threaded network I/O.
# Kernel load-balances incoming packets across I/O threads.
enable_reuseport = true

# Connection idle timeout
# Default: 30 seconds
#
# Connections without activity are closed after this duration.
idle_timeout = { secs = 30, nanos = 0 }

# Connection cleanup interval
# Default: 60 seconds
#
# How often to scan and prune stale connections.
cleanup_interval = { secs = 60, nanos = 0 }

# ==============================================================================
# Monitoring Configuration
# ==============================================================================
[monitoring]
# Enable metrics collection
# Default: true
enable_metrics = true

# Metrics logging interval
# Default: 10 seconds
metrics_interval = { secs = 10, nanos = 0 }

# Enable detailed debug logging
# Default: false
#
# Only enable for troubleshooting (impacts performance).
debug_mode = false

# Enable performance profiling hooks
# Default: false
#
# Enables integration with perf, flamegraph, etc.
enable_profiling = false

# ==============================================================================
# Example Configurations
# ==============================================================================

# High-Throughput Configuration (16-core server)
# ----------------------------------------------
# [network_io]
# threads = 4
# [quic_protocol]
# threads = 4
# [tokio_runtime]
# worker_threads = 8  # 16 - (4+4) = 8
# cpu_mode = "dedicated"
#
# Expected performance:
# - Throughput: 4 × 500K = 2M pps
# - Connections: 200K+
# - Latency: <500µs p99

# Low-Latency Configuration (8-core server)
# -----------------------------------------
# [network_io]
# threads = 2
# thread_priority = "max"  # Requires CAP_SYS_NICE
# [quic_protocol]
# threads = 2
# thread_priority = "high"
# [tokio_runtime]
# worker_threads = 4
# cpu_mode = "dedicated"
#
# Expected performance:
# - Throughput: 2 × 500K = 1M pps
# - Connections: 100K+
# - Latency: <100µs p99

# Development Configuration (4-core laptop)
# -----------------------------------------
# [network_io]
# threads = 1
# enable_cpu_pinning = false
# [quic_protocol]
# threads = 1
# enable_cpu_pinning = false
# [tokio_runtime]
# worker_threads = 3
# cpu_mode = "shared"
# [server]
# max_connections = 1000
# [monitoring]
# debug_mode = true
